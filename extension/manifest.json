{
    "manifest_version" : 3, 
    "name" : "AI Job Applicator",
    "action" : {"default_popup": "index.html"},
    "permission":[
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions" : ["<all_urls>"],
    "content_scripts" : [
        {
            "matches" : ["<all_urls>"],
            "js" : ["src/content/index.js"]
        }
    ],
    "background" : {
        "service_worker" : "src/background/index.js"
    }
}